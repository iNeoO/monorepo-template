{
	"name": "@monorepo-template/drizzle",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"generate": "drizzle-kit generate",
		"migrate": "drizzle-kit migrate",
		"push": "drizzle-kit push",
		"pull": "drizzle-kit pull",
		"reset": "drizzle-kit push --force",
		"drop": "drizzle-kit drop",
		"lint": "biome check"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"license": "ISC",
	"dependencies": {
		"@monorepo-template/infra": "workspace:*",
		"drizzle-orm": "__drizzle-orm__",
		"pg": "__pg__"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"@types/pg": "__@types/pg__",
		"drizzle-kit": "__drizzle-kit__",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
