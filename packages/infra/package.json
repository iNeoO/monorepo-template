{
	"name": "@monorepo-template/infra",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./configs": {
			"import": {
				"types": "./dist/configs/index.d.ts",
				"default": "./dist/configs/index.js"
			}
		},
		"./factories": {
			"import": {
				"types": "./dist/factories/index.d.ts",
				"default": "./dist/factories/index.js"
			}
		},
		"./helpers": {
			"import": {
				"types": "./dist/helpers/index.d.ts",
				"default": "./dist/helpers/index.js"
			}
		},
		"./libs": {
			"import": {
				"types": "./dist/libs/index.d.ts",
				"default": "./dist/libs/index.js"
			}
		},
		"./middlewares": {
			"import": {
				"types": "./dist/middlewares/index.d.ts",
				"default": "./dist/middlewares/index.js"
			}
		},
		"./redis": {
			"import": {
				"types": "./dist/redis/index.d.ts",
				"default": "./dist/redis/index.js"
			}
		},
		"./schemas": {
			"import": {
				"types": "./dist/schemas/index.d.ts",
				"default": "./dist/schemas/index.js"
			}
		},
		"./types": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/types/index.js"
			}
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"lint": "biome check",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"packageManager": "pnpm@11.13.0",
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.2",
		"@hono/zod-validator": "^0.8.0",
		"@monorepo-template/common": "workspace:*",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.76.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/sdk-metrics": "^2.7.1",
		"@opentelemetry/sdk-node": "^0.218.0",
		"@types/node": "catalog:",
		"hono": "catalog:",
		"hono-openapi": "catalog:",
		"openapi-types": "^12.1.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"zod": "catalog:"
	}
}
