{
	"name": "monorepo-template",
	"license": "MIT",
	"scripts": {
		"hono:dev": "pnpm --filter @monorepo-template/hono dev",
		"hono:build": "pnpm --filter @monorepo-template/hono build",
		"infra:build": "pnpm --filter @monorepo-template/infra build",
		"common:build": "pnpm --filter @monorepo-template/common build",
		"services:build": "pnpm --filter @monorepo-template/services build",
		"prisma:init": "dotenv -e .env -- pnpm --filter @monorepo-template/prisma db:init",
		"prisma:emit": "dotenv -e .env -- pnpm --filter @monorepo-template/prisma emit",
		"prisma:build": "pnpm --filter @monorepo-template/prisma build",
		"drizzle:build": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle build",
		"drizzle:drop": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle drop",
		"drizzle:pull": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle pull",
		"drizzle:push": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle push",
		"drizzle:generate": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle generate",
		"drizzle:migrate": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle migrate",
		"drizzle:deploy": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle deploy",
		"drizzle:reset": "dotenv -e .env -- pnpm --filter @monorepo-template/drizzle reset",
		"lint": "pnpm run -r"
	},
	"type": "module",
	"version": "1.0.0",
	"packageManager": "pnpm@11.3.0",
	"devDependencies": {
		"dotenv-cli": "^11.0.0"
	}
}
