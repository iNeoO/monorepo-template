{
	"name": "@monorepo-template/infra",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./configs": {
			"import": {
				"types": "./dist/configs/index.d.ts",
				"default": "./dist/configs/index.js"
			}
		},
		"./factories": {
			"import": {
				"types": "./dist/factories/index.d.ts",
				"default": "./dist/factories/index.js"
			}
		},
		"./helpers": {
			"import": {
				"types": "./dist/helpers/index.d.ts",
				"default": "./dist/helpers/index.js"
			}
		},
		"./libs": {
			"import": {
				"types": "./dist/libs/index.d.ts",
				"default": "./dist/libs/index.js"
			}
		},
		"./middlewares": {
			"import": {
				"types": "./dist/middlewares/index.d.ts",
				"default": "./dist/middlewares/index.js"
			}
		},
		"./redis": {
			"import": {
				"types": "./dist/redis/index.d.ts",
				"default": "./dist/redis/index.js"
			}
		},
		"./schemas": {
			"import": {
				"types": "./dist/schemas/index.d.ts",
				"default": "./dist/schemas/index.js"
			}
		},
		"./types": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/types/index.js"
			}
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"lint": "biome check",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"packageManager": "pnpm@11.13.0",
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@hono/standard-validator": "__@hono/standard-validator__",
		"@hono/zod-validator": "__@hono/zod-validator__",
		"@monorepo-template/common": "workspace:*",
		"@types/node": "catalog:",
		"hono": "catalog:",
		"hono-openapi": "catalog:",
		"openapi-types": "__openapi-types__",
		"pino": "__pino__",
		"pino-pretty": "__pino-pretty__",
		"zod": "catalog:"
	}
}
