{
	"name": "@monorepo-template/hono",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --clear-screen=false src/index.ts",
		"backend:dev": "tsx watch --clear-screen=false src/index.ts",
		"lint": "biome check",
		"build": "rm -rf dist && tsc",
		"backend:start": "node dist/index.js"
	},
	"dependencies": {
		"@hono/node-server": "__@hono/node-server__",
"@hono/standard-validator": "__@hono/standard-validator__",
		"@monorepo-template/common": "workspace:*",
		"@monorepo-template/infra": "workspace:*",
		"@monorepo-template/prisma": "workspace:*",
		"@monorepo-template/services": "workspace:*",
		"@scalar/hono-api-reference": "__@scalar/hono-api-reference__",
		"hono": "catalog:",
		"hono-openapi": "catalog:",
		"zod": "catalog:"
	},
	"exports": {
		"./hc": {
			"import": {
				"types": "./dist/libs/hc.d.ts",
				"default": "./dist/libs/hc.js"
			}
		}
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/node": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
