{
	"compilerOptions": {
		"target": "es2025",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src", "generated"],
	"exclude": ["dist", "node_modules", "prisma.config.ts"]
}
