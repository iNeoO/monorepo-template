{
  "name": "monorepo-template",
  "license": "MIT",
  "scripts": {
    "dev:hono": "pnpm --filter hono-backend start",
    "dev:nest": "pnpm --filter nest-backend start",
    "dev:next": "pnpm --filter next-frontend dev",
    "dev:nuxt": "pnpm --filter nuxt-frontend dev",
    "lint:nuxt": "pnpm --filter nuxt-frontend lint",
    "lint:next": "pnpm --filter next-frontend lint",
    "lint:nest": "pnpm --filter nest-backend lint",
    "lint:back": "pnpm run lint:nest && pnpm run lint:hono",
    "lint:front": "pnpm run lint:nuxt && pnpm run lint:next",
    "lint": "pnpm run lint:back && pnpm run lint:front",
    "prepare": "husky"
  },
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "shared/*"
  ],
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.2",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue,html,css,scss,json,md}": "prettier --write"
  }
}
